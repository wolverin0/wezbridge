{
  "name": "wezbridge",
  "version": "3.4.3",
  "description": "MCP server bridging Claude Code / Codex sessions to WezTerm panes — daemon-only, no browser UI. Backbone of the OmniClaude-via-Telegram pattern.",
  "type": "commonjs",
  "license": "MIT",
  "author": "Pablo Pauola",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wolverin0/wezbridge.git"
  },
  "bugs": {
    "url": "https://github.com/wolverin0/wezbridge/issues"
  },
  "homepage": "https://github.com/wolverin0/wezbridge#readme",
  "keywords": [
    "claude-code",
    "codex",
    "mcp",
    "wezterm",
    "a2a",
    "telegram",
    "multi-agent"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "mcp": "node src/mcp-server.cjs",
    "setup": "node scripts/install.cjs",
    "streamer": "node src/telegram-streamer.cjs",
    "tasks-watcher": "node src/tasks-watcher.cjs",
    "dashboard": "node src/dashboard-server.cjs",
    "dev": "node --watch src/dashboard-server.cjs",
    "start-streamer": "scripts/start-telegram-streamer.cmd",
    "test": "node --require ./test/setup.cjs --test --test-reporter=spec test/*.test.cjs",
    "install-hooks": "node scripts/install-hooks.cjs",
    "install-autostart": "scripts\\install-autostart.cmd",
    "restore-session": "node scripts/restore-session.cjs"
  },
  "dependencies": {},
  "devDependencies": {}
}
