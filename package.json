{
  "name": "wezbridge",
  "version": "3.1.0",
  "description": "Control Claude Code sessions from Telegram — live terminal streaming, voice prompts, native streaming, split panes, inline status. Your phone becomes Mission Control.",
  "main": "src/telegram-bot.cjs",
  "bin": {
    "wezbridge": "src/bot-watchdog.cjs",
    "wezbridge-orchestrate": "src/orchestrator-cli.cjs",
    "wezbridge-omni": "src/omni.cjs"
  },
  "scripts": {
    "start": "pm2 start ecosystem.config.cjs",
    "start:watchdog": "node src/bot-watchdog.cjs",
    "bot": "node src/telegram-bot.cjs",
    "orchestrate": "node src/orchestrator-cli.cjs",
    "omni": "node src/omni.cjs",
    "omni:setup": "node src/omni.cjs --setup",
    "omni:scan": "node src/omni.cjs --scan",
    "dashboard": "node src/dashboard.cjs --open",
    "stop": "pm2 stop wezbridge-bot",
    "logs": "pm2 logs wezbridge-bot",
    "restart": "pm2 restart wezbridge-bot",
    "test": "node src/test-connection.cjs"
  },
  "keywords": [
    "claude",
    "claude-code",
    "telegram",
    "wezterm",
    "ai",
    "terminal",
    "remote-control",
    "mission-control",
    "live-streaming",
    "voice-to-text",
    "whisper",
    "code-diff",
    "session-management",
    "mini-app"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "node-telegram-bot-api": "^0.66.0"
  },
  "optionalDependencies": {
    "form-data": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
