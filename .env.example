# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required: Telegram forum group chat ID (negative number)
# Tip: send a message in the group, the bot logs the chat ID on startup
TELEGRAM_GROUP_ID=-100xxxxxxxxxx

# Optional: Path to WezTerm executable (auto-detected on most systems)
# Windows default: C:\Program Files\WezTerm\wezterm.exe
# macOS default: /Applications/WezTerm.app/Contents/MacOS/wezterm
# Linux default: wezterm (from PATH)
# WEZTERM_PATH=/usr/bin/wezterm

# Optional: Completion poll interval in milliseconds (default: 3000)
# TELEGRAM_POLL_MS=3000

# Optional: Project map as JSON — maps short names to absolute paths
# WEZBRIDGE_PROJECTS={"myapp":"/home/user/projects/myapp","backend":"/home/user/projects/backend"}
